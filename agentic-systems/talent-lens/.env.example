# TalentLens — Environment Variables
# Copy to .env and fill in values

# App
ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/talentlens

# Anthropic (Claude API for assessments)
ANTHROPIC_API_KEY=

# Deepgram (transcription fallback)
DEEPGRAM_API_KEY=

# Fireflies (webhook integration)
FIREFLIES_WEBHOOK_SECRET=

# Slack (notifications)
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# CoderPad (technical challenge results)
CODERPAD_API_KEY=
